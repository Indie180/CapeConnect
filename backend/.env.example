# ─── Core ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# ─── Database ────────────────────────────────────────────────────────────────
# Set USE_SQLITE=true for local development (no PostgreSQL needed)
USE_SQLITE=false
DATABASE_URL=postgres://postgres:postgres@localhost:5432/capeconnect

# ─── Auth & Sessions ─────────────────────────────────────────────────────────
SESSION_TTL_MINUTES=30
REFRESH_TTL_DAYS=14

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# Cannot be '*' in production.
FRONTEND_ORIGIN=http://localhost:5173,http://localhost:4173

# ─── QR Code Security ────────────────────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 32
QR_SECRET=replace-with-a-strong-random-secret

# ─── PayFast (payments) ──────────────────────────────────────────────────────
# Values below are PayFast's public sandbox test credentials — safe for dev.
# REQUIRED in production: replace with your live merchant credentials.
PAYFAST_MERCHANT_ID=10000100
PAYFAST_MERCHANT_KEY=46f0cd694581a
PAYFAST_PASSPHRASE=jt7NOE43FZPn

# ─── Callback URLs ───────────────────────────────────────────────────────────
# REQUIRED in production.
FRONTEND_URL=http://localhost:5173
API_URL=http://localhost:4000

# ─── Monitoring (optional) ───────────────────────────────────────────────────
SENTRY_DSN=
